# This .gitignore file should be placed at the root of your Unity project.
#
# Get latest from https://github.com/github/gitignore/blob/main/Unity.gitignore
#
/[Aa]ssets/
/[Ll]ibrary/
/[Tt]emp/
/[Oo]bj/
/[Bb]uild/
/[Bb]uilds/
/[Ll]ogs/
/[Uu]serSettings/

# MemoryCaptures can get excessive
/[Mm]emoryCaptures/

# Recordings can get excessive
/[Rr]ecordings/

# Exported binaries
*.apk
*.aab
*.unitypackage
*.app

# Gradle cache directory
.gradle/

# Autogenerated JetBrains Rider project files
.idea/
*.sln.iml
.idea.SolutionName.iml

# Visual Studio cache directory
.vs/

# Autogenerated VS/MD/Consulo solution and project files
ExportedObj/
.consulo/
*.csproj
*.unityproj
*.sln
*.suo
*.tmp
*.user
*.userprefs
*.pidb
*.booproj
*.svd
*.pdb
*.opendb
*.IDB
*.VC.db
*.VC.VC.opendb

# Unity3D generated meta files
*.pidb.meta
*.pdb.meta
*.mdb.meta

# Unity3D generated file on crash reports
sysinfo.txt

# Builds
*.apk
*.unitypackage
*.bundle

# Crashlytics generated file
crashlytics-build.properties

# Packed Addressables
/[Aa]ssets/[Aa]ddressable[Aa]ssets[Dd]ata/*/*.bin*

# Temporary auto-generated assets
/[Aa]ssets/[Ss]treamingAssets/aa.meta
/[Aa]ssets/[Ss]treamingAssets/aa/*

# Nested Unity Project in 'My project'
My project/[Ll]ibrary/
My project/[Tt]emp/
My project/[Oo]bj/
My project/[Bb]uild/
My project/[Bb]uilds/
My project/[Ll]ogs/
My project/[Uu]serSettings/
My project/[Mm]emoryCaptures/
My project/[Rr]ecordings/
My project/*.csproj
My project/*.sln
My project/*.userprefs
My project/*.pidb
My project/*.pdb
My project/*.VC.db
My project/*.VC.VC.opendb
My project/.vs/
My project/.idea/
My project/*.suo

# System Files
.DS_Store
Thumbs.db

# Extra Exclusions
*.png
*-Antigravity.md
*Claude.md
Unity_Wiring_Guide.md
ModularCombatSystem_Guide.md
